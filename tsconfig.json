{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "declaration": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "lib": ["ES2023"],
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "@anthropic/ink": ["./packages/ink/src/index.ts"],
      "@anthropic/ink/*": ["./packages/ink/src/*"],
      "@deepicode/core": ["./packages/core/src/index.ts"],
      "@deepicode/core/*": ["./packages/core/src/*"],
      "@deepicode/ink": ["./packages/ink/src/index.ts"],
      "@deepicode/ink/*": ["./packages/ink/src/*"],
      "@deepicode/security": ["./packages/security/src/index.ts"],
      "@deepicode/security/*": ["./packages/security/src/*"],
      "@deepicode/mcp": ["./packages/mcp/src/index.ts"],
      "@deepicode/mcp/*": ["./packages/mcp/src/*"],
      "@deepicode/tools": ["./packages/tools/src/index.ts"],
      "@deepicode/tools/*": ["./packages/tools/src/*"],
      "@deepicode/tui": ["./packages/tui/src/index.ts"],
      "@deepicode/tui/*": ["./packages/tui/src/*"]
    }
  },
  "include": ["packages/*/src/**/*.ts", "packages/*/src/**/*.tsx", "types/**/*.d.ts"],
  "exclude": ["node_modules", "dist", "**/__tests__/**", "packages/tools/src/skills/**"]
}
